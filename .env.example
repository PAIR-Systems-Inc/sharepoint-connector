# SharePoint Connector Configuration
# Copy this file to .env and fill in your actual credentials

# Azure AD Application Credentials
SHAREPOINT_CLIENT_ID=your-client-id-here
SHAREPOINT_TENANT_ID=your-tenant-id-here
SHAREPOINT_CLIENT_SECRET=your-client-secret-here

# SharePoint Site Configuration
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite

# Optional: Search Configuration
SHAREPOINT_SEARCH_SCOPE=ALL
SHAREPOINT_FOLDER_PATH=
SHAREPOINT_START_DATE=2024-01-01

# Goodmem configurations
GOODMEM_BASE_URL=your-goodmem-url
GOODMEM_API_KEY=your-goodmem-api-key
# Optional: use this space instead of lookup/create by site URL
# DEFAULT_SPACE_ID=your-space-id-here
# Optional: embedder used when creating a new space (ignored if DEFAULT_SPACE_ID is set)
DEFAULT_EMBEDDER_ID=019bed68-b36f-73d7-a132-4112a2efd11d

# Graph sync (listener.py) – Microsoft Graph API webhooks for SharePoint → Goodmem

SYNC_NOTIFICATION_URL=https://your-listener.com/sync/webhook
SYNC_CLIENT_STATE=your-secret-client-state-string
SYNC_PORT=5000

# Fly.io (optional, for deploy_fly_io.sh)
# FLY_ORG=acme-ai
# FLY_REGION=sjc
# OPENAI_API_KEY=sk-your-openai-key # Optional for Fly.io deployment: if set, deploy_fly_io.sh creates a text-embedding-3-small OpenAI embedder after Goodmem setup

