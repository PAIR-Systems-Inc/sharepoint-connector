# ============================================================================
# SharePoint Connector configuration
#
# Copy this file to .env and fill in your values:   cp .env.example .env
#
# Convention in this file:
#   • Uncommented lines are the values you normally set.
#   • Commented (#) lines are optional, auto-filled by the deploy script, or an alternative — the note says which.
#
# What to set, by how you sync:
#   • Manual / periodic sync (sync_once.py):     Azure & SharePoint  +  Goodmem (A)
#   • Event-triggered sync (deploy_fly_io.sh):   Azure & SharePoint  +  Fly.io  +  Goodmem (A)
#       — with "--hands-free": skip Goodmem (A), set OPENAI_API_KEY instead; the script provisions Goodmem.
#       — the Graph webhook group is generated/written for you by the deploy script.
# ============================================================================

# ── Azure AD & SharePoint — REQUIRED for every mode (ask your IT for the values) ──
AZURE_AD_CLIENT_ID=your-client-id-here          # Azure AD app (client) ID
AZURE_AD_TENANT_ID=your-tenant-id-here          # Azure AD directory (tenant) ID
AZURE_AD_CLIENT_SECRET=your-client-secret-here  # Azure AD app client secret
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite  # Site whose drive is synced
# Optional:
# AZURE_AD_OAUTH_TOKEN_MINUTES=60   # Reuse an access token this many minutes before refresh. Default 60 (range 10–1440).
# SHAREPOINT_FOLDER_PATH=           # Restrict a one-time sync (sync-once) to one folder, e.g. Reports/2026. Default: whole drive. (The listener always syncs the whole drive.)
# SHAREPOINT_MAX_FILE_MB=100        # Skip (don't ingest) files larger than this many MB — avoids buffering a huge file in memory. Default 100; 0 = no cap. Skips are recorded in GET /syncs.
# GRAPH_MAX_DELETE_RATIO=0.5        # Safety guard (sync-once and listener): refuse a full sync that would delete more than this fraction of existing memories (a likely partial listing). Default 0.5; set 1 to allow large deletions.
# SHAREPOINT_SEARCH_SCOPE=ALL       # RESERVED — not yet implemented (accepted but ignored).
# SHAREPOINT_START_DATE=2024-01-01  # RESERVED — not yet implemented (accepted but ignored).

# ── Goodmem — choose ONE of (A) or (B) ──
#  (A) Goodmem already exists — point at it (manual sync, and the listener when Goodmem runs elsewhere):
GOODMEM_BASE_URL=your-goodmem-url           # Base URL of your Goodmem instance, including the https:// scheme
GOODMEM_API_KEY=your-goodmem-api-key        # Goodmem API key
#     Set EXACTLY ONE of the next two (GOODMEM_SPACE_ID wins if both are set):
GOODMEM_SPACE_ID=your-space-id-here         # Sync into this existing space
# GOODMEM_EMBEDDER_ID=your-embedder-id-here # …or create a new space "SharePoint_{Org}_{Site}" using this embedder
#     (Legacy aliases also accepted: SPACE_ID / DEFAULT_SPACE_ID, EMBEDDER_ID / DEFAULT_EMBEDDER_ID; the GOODMEM_-prefixed name wins.)
# GOODMEM_EXTRACT_PAGE_IMAGES=false          # Truthy (1/true/yes/on) → ask Goodmem to extract page images (e.g. PDF page screenshots). Default off.
#
#  (B) Let "deploy_fly_io.sh --hands-free" provision Goodmem — leave (A) blank and set only:
# OPENAI_API_KEY=sk-your-openai-key         # Creates the text-embedding-3-small embedder for the new Goodmem.

# ── Graph webhook — EVENT-TRIGGERED SYNC ONLY; choose ONE of (A) or (B) ──
#  (A) Deploy with deploy_fly_io.sh: leave both blank — the script generates GRAPH_CLIENT_STATE
#      and writes GRAPH_NOTIFICATION_URL for you.
#  (B) Manual / non-Fly deployment: set both yourself:
# GRAPH_CLIENT_STATE=your-secret-string  # Any secret string; Graph echoes it back so the listener can verify a notification is genuine.
# GRAPH_NOTIFICATION_URL=https://your-listener.example.com/sync/webhook  # Your listener's public HTTPS webhook URL.
# Optional (either case):
# PORT=8080                        # Port the listener binds to (PaaS convention; wins over GRAPH_PORT). The Docker image sets 8080.
# GRAPH_PORT=5000                  # Port the listener binds to if PORT is unset. Default 5000.
# GRAPH_SUBSCRIPTION_MINUTES=4320  # Graph subscription lifetime before auto-renew. Default 4320 (3 days); min 45, max 42300 (~30 days).
# GRAPH_FULL_SYNC_MINUTES=2160     # Periodic safety full-sync interval (reconciles anything missed by delta). Default = half the subscription lifetime; 0 disables.
# GRAPH_MAX_RETRIES=5              # Retries per Graph call on 429/5xx/network (honors Retry-After, jittered backoff). Default 5 (range 0–10).
# GRAPH_DELTA_TOKEN_FILE=.graph_delta_link  # Durable state file (delta cursor); pending-retry sets live in the same dir. On Fly it's /data (a persistent volume); locally defaults to the working dir.
# GRAPH_MAX_ITEM_ATTEMPTS=10       # Listener only: transient retries for a failing file before it's parked (dead-lettered) instead of retried forever. Parked items appear in GET /syncs (status=dead) and the sharepoint_pending_dead metric. Default 10.
# SYNC_HISTORY_RETENTION_DAYS=90   # Listener only: prune GET /syncs history rows older than this many days (keeps the /data volume from filling). Default 90; 0 = keep forever.
# LOG_LEVEL=info                   # Listener only: structured-log verbosity — debug | info | warn | error. Default info.
# LOG_FORMAT=json                  # Listener only: structured-log format — json (for log shippers) | text (friendlier locally). Default json.

# ── Fly.io — REQUIRED for event-triggered sync deployed via deploy_fly_io.sh; skip for manual sync. ──
FLY_CLUSTER=your-cluster-name      # Prefix for Fly app names; must be unique. Creates <FLY_CLUSTER>-listener (and -goodmem, -goodmem-postgres with --hands-free).
# Optional:
# FLY_ORG=your-fly-org             # Fly.io org slug. Set it to skip the prompt when you belong to multiple orgs.
# FLY_REGION=sjc                   # Fly.io region. Default sjc.
