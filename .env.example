# SharePoint Connector Configuration
# Copy this file to .env and fill in your actual credentials

# Azure AD Application Credentials
AZURE_AD_CLIENT_ID=your-client-id-here
AZURE_AD_TENANT_ID=your-tenant-id-here
AZURE_AD_CLIENT_SECRET=your-client-secret-here
# Optional: max token validity in minutes — how long we consider the token valid before refreshing (default 60). Range 10–1440 (10 min–24 h).
# AZURE_AD_OAUTH_TOKEN_MINUTES=60

# SharePoint Site Configuration
SHAREPOINT_SITE_URL=https://your-tenant.sharepoint.com/sites/YourSite
SHAREPOINT_SEARCH_SCOPE=ALL # Optional
SHAREPOINT_FOLDER_PATH=     # Optional
SHAREPOINT_START_DATE=2024-01-01 # Optional

# Goodmem configurations (Effective and required only when Goodmem is already setup)
GOODMEM_BASE_URL=your-goodmem-url
GOODMEM_API_KEY=your-goodmem-api-key
# GOODMEM_SPACE_ID=your-space-id-here # Using this Goodmem space only 
# GOODMEM_EMBEDDER_ID=your-embedder-id-here # Creating a new Goodmem space with this embedder
# Note: Either GOODMEM_SPACE_ID or GOODMEM_EMBEDDER_ID is required. GOODMEM_SPACE_ID takes precedence over GOODMEM_EMBEDDER_ID.

# Graph sync (listener.py) – Microsoft Graph API webhooks for SharePoint → Goodmem
# clientState and notificationUrl (Graph subscription API names)
GRAPH_CLIENT_STATE=your-secret-client-state-string
GRAPH_PORT=5000
GRAPH_NOTIFICATION_URL=https://your-listener.com/sync/webhook # Required when deploying listener; deploy script writes this after creating the Fly app.
# Optional: subscription length in minutes (default 4320 = 3 days). Min 45 minutes, max 42300 minutes (~30 days). If unset, use Microsoft default -- which is yet unknown to Forrest. Use a short value (e.g. 2) to test re-subscribe.
# GRAPH_SUBSCRIPTION_MINUTES=4320

# Fly.io (for deploy_fly_io.sh)
FLY_CLUSTER=your-app-cluster-name-here
FLY_ORG=your-fly-org-here
FLY_REGION=your-fly-region-here
OPENAI_API_KEY=sk-your-openai-key # Required and effective for hands-free deployment only. Creates a text-embedding-3-small OpenAI embedder after Goodmem setup

